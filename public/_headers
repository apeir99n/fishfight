# Cloudflare Pages: per-path response headers.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# HTML should always revalidate so users get new game versions immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Hashed build assets (Vite emits /assets/*-<hash>.{js,css}) are immutable.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Baseline security headers for the whole site.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: interest-cohort=()
